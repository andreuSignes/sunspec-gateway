# =============================================================================
# Solar Home Gateway — environment configuration
# =============================================================================
# Copy to `.env` and fill in the values for your inverter. The gateway loads
# this file via @nestjs/config at boot; an invalid value crashes the process
# immediately (validated against [1, 65535] for ports, required INVERTER_SN).
#
# Tip: leave the defaults for a fast smoke-test on a fresh clone. Set real
# values for production — see README.md §"Configuration" for each key.
# =============================================================================

# --- Inverter (Solplanet ASW H-S2 HTTP CGI) ----------------------------------

# CGI base URL. The adapter appends `/getdevdata.cgi?device=...&sn=...`.
INVERTER_BASE_URL=http://192.168.1.50:8484

# Solplanet device id (the `device` query param). 2 is the LAN-attached
# inverter default for most ASW H-S2 installs.
INVERTER_DEVICE_ID=2

# Inverter serial number (REQUIRED). Set this — empty string will refuse to boot.
INVERTER_SN=

# Wall-clock budget for the CGI HTTP call (ms). Independent of any per-request
# axios timeout inside the adapter.
INVERTER_TIMEOUT_MS=4000

# Sched tick interval (ms). The cron decorator is currently fixed at 5 s;
# this knob is wired so a future PR can swap to a dynamic interval.
POLL_INTERVAL_MS=5000

# Adapter-internal abort budget (ms). Belt-and-braces over INVERTER_TIMEOUT_MS.
POLL_TIMEOUT_MS=3000

# --- Modbus TCP server -------------------------------------------------------

# Bind address. MUST be a private interface in production (e.g. 192.168.1.x).
# 0.0.0.0 binds every interface — fine for dev, dangerous for prod because
# Modbus TCP has no authentication or encryption.
MODBUS_HOST=0.0.0.0
MODBUS_PORT=5020

# Modbus slave id (1..247 per Modbus spec). Reported in SunSpec M1.DA.
MODBUS_UNIT_ID=1

# --- State bus + lifecycle ---------------------------------------------------

# Stale-data threshold (ms). After this many ms with no fresh poll, snapshot()
# zeros production values and sets isStale=true.
STALE_AFTER_MS=30000

# Graceful-close budget for OnApplicationShutdown (ms). The Modbus server
# gets this long to drain in-flight reads before the process exits.
SHUTDOWN_TIMEOUT_MS=5000

# --- HTTP (only /healthz is exposed) -----------------------------------------

# HTTP port for the liveness probe. Keep it on a different port than Modbus.
HTTP_PORT=3000