{
  "name": "sunspec-gateway",
  "version": "0.1.0",
  "description": "SunSpec Modbus Gateway — NestJS microservice that polls a Solplanet ASW H-S2 inverter via HTTP CGI and exposes it as a SunSpec-conformant Modbus TCP server for Home Assistant.",
  "private": true,
  "engines": {"node": ">=20"},
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node --transpile-only src/main.ts",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/schedule": "^4.1.0",
    "axios": "^1.7.0",
    "modbus-serial": "^8.0.25",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
